# WordPress REST API base URL (no trailing slash)
# Before DNS migration:
WP_API_URL=https://aaron.kr/wp-json/wp/v2
# After WordPress moves to lab.aaron.kr subdomain:
# WP_API_URL=https://lab.aaron.kr/wp-json/wp/v2

# WordPress post type slug for design/project posts
# Find in WP Admin → Settings → Permalinks, or check
# https://aaron.kr/wp-json/wp/v2/types
WP_PROJECT_POST_TYPE=project

# Category slug (or numeric ID) for "beyond" posts
WP_BEYOND_CATEGORY=beyond

# How many writing posts to show on homepage
WP_WRITING_PER_PAGE=8
