# Copy this file to .env.local and fill in the values.
# Only ONE WP_API_URL should be active at a time — comment out the other.

# ── LOCAL DEVELOPMENT (LocalWP) ──────────────────────────────────────────────
# Change 'aaronkr.local' to whatever LocalWP assigned your site.
WP_API_URL=http://aaronkr.local/wp-json/wp/v2

# ── PRODUCTION (Dreamhost VPS at notes.aaron.kr) ─────────────────────────────
# Uncomment this and comment out the local line when deploying to Vercel.
# WP_API_URL=https://notes.aaron.kr/wp-json/wp/v2

# ── Post type and category slugs ─────────────────────────────────────────────
# These must match the slugs registered in aaron-kr-api.php
WP_PROJECT_POST_TYPE=portfolio       # → /wp-json/wp/v2/portfolio
WP_BEYOND_CATEGORY=beyond            # category slug for personal/beyond posts
WP_WRITING_PER_PAGE=8
