# Copy this file to .env.local for local development. Never edit this for deployment.
# Vercel manages production env vars in its own dashboard — .env.local is gitignored
# and never sent to Vercel. You never need to change this file when deploying.

# ── LOCAL DEVELOPMENT (LocalWP) ──────────────────────────────────────────────
# Keep this as-is. Vercel uses its own WP_API_URL pointing to notes.aaron.kr.
WP_API_URL=http://aaronkr.local/wp-json/wp/v2

# ── Post type and category slugs ─────────────────────────────────────────────
# These must match the slugs registered in mu-plugins/aaron-kr-api.php
WP_PROJECT_POST_TYPE=portfolio       # → /wp-json/wp/v2/portfolio
WP_BEYOND_CATEGORY=beyond            # category slug for personal/beyond posts
WP_WRITING_PER_PAGE=8

# ── Giscus comments (optional) ───────────────────────────────────────────────
# Get these values from https://giscus.app after enabling GitHub Discussions.
# Leave blank locally — comments simply won't render.
NEXT_PUBLIC_GISCUS_REPO=
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=Comments
NEXT_PUBLIC_GISCUS_CATEGORY_ID=
