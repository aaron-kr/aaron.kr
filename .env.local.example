# ── LOCAL DEVELOPMENT ────────────────────────────────────────────────────────
# Point at your LocalWP instance.
# Change 'aaronkr.local' to whatever LocalWP assigned your site.
WP_API_URL=http://aaronkr.local/wp-json/wp/v2

# ── PRODUCTION (Dreamhost VPS) ───────────────────────────────────────────────
# Uncomment when deploying to Vercel.
# WP_API_URL=https://lab.aaron.kr/wp-json/wp/v2

# Post type slugs (match what's in aaron-kr-api.php mu-plugin)
WP_PROJECT_POST_TYPE=portfolio       # /wp-json/wp/v2/portfolio
WP_BEYOND_CATEGORY=beyond            # category slug for personal posts
WP_WRITING_PER_PAGE=8
